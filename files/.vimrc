" Colorscheme settings
let base16colorspace=256
colorscheme base16-default-dark

" General settings
set cursorline
set nowrap
set number
set showmatch
syntax on

" Search settings
set hlsearch
set ignorecase
set incsearch
set smartcase

" Tab settings
set autoindent
set expandtab
set shiftwidth=2
set softtabstop=2
set tabstop=2
